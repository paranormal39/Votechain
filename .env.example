# ── AgilityCore ──────────────────────────────────────────────────────────────
AGILITY_BASE_URL=https://agilitycore-production.up.railway.app
AGILITY_ADMIN_KEY=your_admin_api_key_here

# ── Midnight On-Chain Integration (Phase 6) ───────────────────────────────────
# Server-side wallet seed (hex, 64 chars) — the deployer wallet used to submit txs.
# MIDNIGHT_WALLET_SEED=your_64_char_hex_seed_here

# Admin secret key (hex, 64 chars) — derived during DAO deployment, kept private.
# MIDNIGHT_ADMIN_SECRET=your_64_char_hex_admin_secret_here

# Proof server — Windows host IP from WSL (run: cat /etc/resolv.conf | grep nameserver)
MIDNIGHT_PROOF_SERVER_URL=http://172.22.96.1:6300

# Deployed contract addresses on Midnight Preview (from votechain-deployment.md)
MIDNIGHT_DAO_ADDRESS=d4e3299040a14895c5a2f735b41dc57cd7c3127734baaf765bef136f4b84d931
MIDNIGHT_VOTING_ADDRESS=edb5f277d19da414b8d51a728edda92edfd1f9890b389412ec0abdae071acaf5
MIDNIGHT_DELEGATION_ADDRESS=75c21a6676ff1dc542ae654ba36eb1d6c8bb990d508b76374ab49e1291c9d4ca
MIDNIGHT_TREASURY_ADDRESS=61719733dd930830d45eb2055012a8e74bdf8f16a49e99a79c4673501f5b59b0
MIDNIGHT_FEEDBACK_ADDRESS=b5a939e58fb11b31f5e34baad05f9a40c95ed8ba4292d7fbecfd63680f49948e

# Launchpad escrow contract (Compact). Empty until authored + deployed to Preview.
# When unset, Midnight escrow writes are skipped (best-effort) and the funding
# flow runs on XRPL/Xahau only.
# MIDNIGHT_ESCROW_ADDRESS=

# ── Launchpad ─────────────────────────────────────────────────────────────────
# AES-256-GCM key (any strong string) used to encrypt escrow signing seeds and
# the Discord↔wallet identity mapping at rest. REQUIRED in production — if unset,
# an ephemeral key is generated and encrypted data won't survive a restart.
# LAUNCHPAD_ENCRYPTION_KEY=replace_with_a_long_random_secret

# ── Discord bot (Phase B — hosted multi-tenant) ───────────────────────────────
# Create an application at https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your_bot_token
# DISCORD_CLIENT_ID=your_application_client_id
# DISCORD_CLIENT_SECRET=your_oauth2_client_secret
# Application PUBLIC KEY (General Information tab) — verifies inbound slash-command
# signatures. REQUIRED for the /api/discord/interactions endpoint.
# DISCORD_PUBLIC_KEY=your_application_public_key
# Optional: register slash commands instantly to this one guild (test server id).
# Leave unset to register commands globally (~1h to propagate).
# DISCORD_GUILD_ID=your_test_guild_id
# Shared secret the bot uses to authenticate to VoteChain internal endpoints.
# BOT_INTERNAL_SECRET=replace_with_a_long_random_secret
# Public base URL of the web app the bot deep-links to for private voting.
# Must be the SAME public HTTPS URL set as the Interactions Endpoint URL.
# APP_PUBLIC_URL=http://localhost:3000

# ── Xaman (XUMM) Wallet ───────────────────────────────────────────────────────
# Required only for Xaman QR sign-in support (XRPL / Xahau wallets).
# Create an app at https://apps.xaman.dev and paste the credentials here.
# XAMAN_API_KEY=your_xaman_api_key
# XAMAN_API_SECRET=your_xaman_api_secret

# ── Chain RPC endpoints ───────────────────────────────────────────────────────
# Used for on-chain membership verification, contribution scanning, and escrow.
# Defaults target testnet on port 443; override for mainnet.
# NOTE: the classic Ripple JSON-RPC ports (51234 / wss 51233) are non-standard
# and some networks/firewalls (corporate, certain WSL setups) block them,
# causing request timeouts. The XRPL Labs testnet node serves the same JSON-RPC
# over HTTPS:443 and works even on those restricted networks.
#
# Pick the network your wallet uses (they are SEPARATE ledgers — an account on
# devnet does not exist on testnet and vice-versa):
#   Testnet (port 443, firewall-friendly): https://testnet.xrpl-labs.com/
#   Testnet (classic port 51234):           https://s.altnet.rippletest.net:51234/
#   Devnet  (classic port 51234):           https://s.devnet.rippletest.net:51234/
XRPL_RPC_URL=https://s.devnet.rippletest.net:51234/
XAHAU_RPC_URL=https://xahau-test.net/

# ── Database (future) ─────────────────────────────────────────────────────────
# Currently uses a JSON file store (.data/). Set this to migrate to a DB.
# DATABASE_URL="file:./votechain.db"
